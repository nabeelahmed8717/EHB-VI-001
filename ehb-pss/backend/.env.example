# ─────────────────────────────────────────────────────────────────────────────
# PSS API — Environment Variables
# Copy this file to .env and fill in values before running locally.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Application
PORT=3001
NODE_ENV=development

# MongoDB — pss_db (PSS owns this database; all platforms have their own DBs)
MONGODB_URI=mongodb://localhost:27017/pss_db

# JWT — used for PSS admin dashboard and internal user sessions
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=24h

# EHB Master Admin Key — used for platform registration endpoint
# Only EHB infrastructure team should have this key
EHB_ADMIN_KEY=ehb-master-admin-key-change-in-production

# PSS Webhook Signing Secret — PSS signs all webhook calls to platform backends
# Platforms use this to verify webhook authenticity via x-pss-signature header
PSS_WEBHOOK_SIGNING_SECRET=whsec-change-in-production
