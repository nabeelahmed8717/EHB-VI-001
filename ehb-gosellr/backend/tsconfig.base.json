{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node10",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "paths": {
      "@ehb-gosellr/types": ["libs/gosellr-types/src/index.ts"],
      "@ehb-gosellr/utils": ["libs/gosellr-utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
